# Clinical Co-Pilot Environment Template (.env.example)
# Copy this file to '.env' and fill in your actual API keys before running locally.
# Never commit your actual '.env' file containing real secret keys to Git!

# Flag to use cloud APIs exclusively (set to false for cloud/HF Spaces deployment)
USE_LOCAL_MODELS=false

# OpenRouter API Key for LLM reasoning (Mistral-7B / Llama-3)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Cohere API Key for semantic embeddings (embed-english-v3.0)
COHERE_API_KEY="your_cohere_api_key_here"

# Groq API Key for ultra-fast Whisper audio transcription
GROQ_API_KEY="your_groq_api_key_here"

# Pinecone Cloud Vector Database credentials
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_INDEX="clinical-copilot"
